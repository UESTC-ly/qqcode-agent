# Provider options: anthropic (Anthropic Messages API) or openai_compat (OpenAI-compatible Chat Completions)
PROVIDER=anthropic
MODEL=claude-3-5-sonnet-20241022

# Anthropic-compatible mode
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=

# OpenAI-compatible mode, e.g. DeepSeek: OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=your_openai_or_compatible_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: required only for E2B code execution tools
E2B_API_KEY=your_e2b_api_key
